# ─── Deployer (Hardhat / Fuji) ────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=your_metamask_private_key_here
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
SNOWTRACE_API_KEY=your_snowtrace_api_key

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_CONTRACT_ADDRESS=0xYourContractAddressHere
VITE_CHAIN_ID=43113

# ─── Cloudflare Secrets (set via `wrangler secret put <NAME>`) ───────────────
# ADMIN_TOKEN      → random string, paste into admin dashboard to enable uploads + API key mgmt
# CONTRACT_ADDRESS → same as VITE_CONTRACT_ADDRESS
# RPC_URL          → https://api.avax-test.network/ext/bc/C/rpc
# WDK_API_URL      → https://api.tether.to/v1/wdk
# WDK_API_KEY      → your Tether WDK key

# ─── Cloudflare KV (for API keys, webhooks, asset fallback) ──────────────────
# wrangler kv:namespace create "GCH_STORE"
# → paste the returned ID into wrangler.toml [[kv_namespaces]]

# ─── Cloudflare R2 (for skin + content uploads) ───────────────────────────────
# wrangler r2 bucket create gamechanger-assets
# → uncomment [[r2_buckets]] in wrangler.toml
