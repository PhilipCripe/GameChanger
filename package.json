{
  "name": "gamechanger-marketplace",
  "version": "1.0.0",
  "description": "GameChanger SDK – multi-chain payments on Avalanche Fuji, hosted on Cloudflare Pages",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":            "vite",
    "build":          "vite build",
    "preview":        "vite preview",
    "pages:deploy":   "npx wrangler@4.69.0 pages deploy dist --project-name gamechanger-market",
    "deploy":         "npm run build && npm run pages:deploy",
    "hardhat:deploy": "hardhat run scripts/deploy.js --network fuji",
    "hardhat:verify": "hardhat verify --network fuji"
  },
  "dependencies": {
    "ethers":           "^6.9.0",
    "react":            "^18.3.1",
    "react-dom":        "^18.3.1",
    "react-router-dom": "^6.22.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts":          "^5.0.1",
    "@vitejs/plugin-react":             "^4.2.1",
    "autoprefixer":                     "^10.4.17",
    "dotenv":                           "^16.4.1",
    "hardhat":                          "^2.19.4",
    "postcss":                          "^8.4.35",
    "tailwindcss":                      "^3.4.1",
    "vite":                             "^5.1.0",
    "wrangler":                         "4.69.0"
  }
}
